  <!-- Footer -->
  <footer class="footer">
    <div class="footer-content">
      <div class="footer-section">
        <h3>Al-Daoudi Bodybuilding Club</h3>
        <p>غير حياتك، غير مستقبلك.</p>
        <div class="social-links">
          <a href="#"><span class="material-icons">facebook</span></a>
          <a href="#"><span class="material-icons">instagram</span></a>
          <a href="#"><span class="material-icons">twitter</span></a>
          <a href="#"><span class="material-icons">youtube</span></a>
        </div>
      </div>
      <div class="footer-section">
        <h3>روابط سريعة</h3>
        <ul>
          <li><a href="index.html">الرئيسية</a></li>
          <li><a href="services.html">الخدمات</a></li>
          <li><a href="membership.html">الاشتراكات</a></li>
          <li><a href="contact.html">اتصل بنا</a></li>
          <li><a href="messages.html">الرسائل</a></li>
        </ul>
      </div>
      <div class="footer-section">
        <h3>معلومات الاتصال</h3>
        <p><span class="material-icons" style="font-size:1rem; vertical-align:middle;">location_on</span> المغرب، الدار البيضاء</p>
        <p><span class="material-icons" style="font-size:1rem; vertical-align:middle;">phone</span> 06 33 37 77 22</p>
        <p><span class="material-icons" style="font-size:1rem; vertical-align:middle;">email</span> Clubsportdaoudi2000@gmail.com</p>
      </div>
      <div class="footer-section">
        <h3>ساعات العمل</h3>
        <p>الاثنين (الرجال): 6صباحاً - 12 ظهراً</p>
        <p>الاثنين (النساء): 12 ظهراً - 4 عصراً</p>
        <p>الثلاثاء - الجمعة: 6 صباحاً - 11 مساءً</p>
        <p>السبت - الأحد: 8 صباحاً - 8 مساءً</p>
      </div>
    </div>
    <div class="footer-bottom">
