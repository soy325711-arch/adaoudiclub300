    </div>
  </footer>

  <script src="js/main.js"></script>
  <script>
    // Contact form handler - Send to server API
    document.getElementById('contact-form').addEventListener('submit', function(e) {
      e.preventDefault();
      
      const name = document.getElementById('name').value;
      const email = document.getElementById('email').value;
      const phone = document.getElementById('phone').value;
      const message = document.getElementById('message').value;
      
      // Send to server API
      fetch('/api/messages', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json'
        },
        body: JSON.stringify({
          name: name,
          email: email,
          phone: phone,
          message: message
        })
      })
      .then(response => response.json())
      .then(data => {
        if (data.success) {
          // Show success message
          document.getElementById('contact-form').style.display = 'none';
          document.getElementById('form-success').style.display = 'block';
        } else {
          alert('حدث خطأ. يرجى المحاولة مرة أخرى.');
        }
      })
      .catch(error => {
        console.error('Error:', error);
        // Fallback to localStorage if API fails
        let messages = JSON.parse(localStorage.getItem('gym_messages')) || [];
        messages.push({
          id: Date.now(),
          name: name,
          email: email,
          phone: phone,
          message: message,
          date: new Date().toISOString(),
          status: 'unread',
          reply: null,
          replyDate: null
        });
        localStorage.setItem('gym_messages', JSON.stringify(messages));
        document.getElementById('contact-form').style.display = 'none';
        document.getElementById('form-success').style.display = 'block';
      });
    });

    // Load dynamic website settings on contact page
    document.addEventListener('DOMContentLoaded', function() {
      const settings = JSON.parse(localStorage.getItem('gym_site_settings'));
      
      if (settings) {
        // Update page title
        if (settings.siteName) {
          document.title = 'اتصل بنا - ' + settings.siteName;
        }
        
        // Update logo
        if (settings.siteName) {
          document.querySelectorAll('.logo').forEach(el => {
            const parts = settings.siteName.split(' ');
            if (parts.length > 1) {
              el.innerHTML = parts[0] + '<span>' + parts.slice(1).join(' ') + '</span>';
            } else {
              el.innerHTML = settings.siteName;
            }
          });
        }
        
        // Update contact info - Location
        const locationP = document.querySelector('.contact-info-item:nth-child(1) .contact-details p');
        if (locationP && settings.siteAddress) {
          locationP.textContent = settings.siteAddress;
        }
        
        // Update contact info - Phone
        const phoneP = document.querySelector('.contact-info-item:nth-child(2) .contact-details p');
        if (phoneP && settings.sitePhone) {
          phoneP.textContent = settings.sitePhone;
        }
        
        // Update contact info - Email
        const emailP = document.querySelector('.contact-info-item:nth-child(3) .contact-details p');
        if (emailP && settings.siteEmail) {
          emailP.textContent = settings.siteEmail;
        }
        
        // Update hours in contact page
        const hoursContainer = document.querySelector('.contact-info-item:nth-child(4) .contact-details');
        if (hoursContainer) {
          let hoursHTML = '';
          if (settings.hoursMondayMen) {
            hoursHTML += '<p><strong>الاثنين (الرجال):</strong> ' + settings.hoursMondayMen + '</p>';
          }
          if (settings.hoursMondayWomen) {
            hoursHTML += '<p><strong>الاثنين (النساء):</strong> ' + settings.hoursMondayWomen + '</p>';
          }
          if (settings.hoursWeekdays) {
            hoursHTML += '<p><strong>الثلاثاء - الجمعة:</strong> ' + settings.hoursWeekdays + '</p>';
          }
          if (settings.hoursWeekend) {
            hoursHTML += '<p><strong>السبت - الأحد:</strong> ' + settings.hoursWeekend + '</p>';
          }
          hoursContainer.innerHTML = hoursHTML;
        }
        
        // Update footer - Address
        const footerSections = document.querySelectorAll('.footer-section');
        if (footerSections[2]) {
          const footerPs = footerSections[2].querySelectorAll('p');
          if (footerPs[0] && settings.siteAddress) {
            footerPs[0].innerHTML = '<span class="material-icons" style="font-size:1rem; vertical-align:middle;">location_on</span> ' + settings.siteAddress;
          }
          if (footerPs[1] && settings.sitePhone) {
            footerPs[1].innerHTML = '<span class="material-icons" style="font-size:1rem; vertical-align:middle;">phone</span> ' + settings.sitePhone;
          }
          if (footerPs[2] && settings.siteEmail) {
            footerPs[2].innerHTML = '<span class="material-icons" style="font-size:1rem; vertical-align:middle;">email</span> ' + settings.siteEmail;
          }
        }
        
        // Update footer hours
        if (footerSections[3]) {
          let footerHoursHTML = '';
          if (settings.hoursMondayMen) {
            footerHoursHTML += '<p>الاثنين (الرجال): ' + settings.hoursMondayMen + '</p>';
          }
          if (settings.hoursMondayWomen) {
            footerHoursHTML += '<p>الاثنين (النساء): ' + settings.hoursMondayWomen + '</p>';
          }
          if (settings.hoursWeekdays) {
            footerHoursHTML += '<p>الثلاثاء - الجمعة: ' + settings.hoursWeekdays + '</p>';
          }
          if (settings.hoursWeekend) {
            footerHoursHTML += '<p>السبت - الأحد: ' + settings.hoursWeekend + '</p>';
          }
          footerSections[3].innerHTML = '<h3>ساعات العمل</h3>' + footerHoursHTML;
        }
        
        // Update footer text
        if (settings.footerText && footerSections[0]) {
          const footerTextP = footerSections[0].querySelector('p');
          if (footerTextP) {
            footerTextP.textContent = settings.footerText;
          }
        }
      }
    });
  </script>
</body>
</html>

